#!/usr/bin/with-contenv bash
# Installs the dev-built agent binary from the host-mounted module directory.
# The LSIO fail2ban image is Alpine (musl): build on the host with:
#   cd _dev/fail2ban-ui-agent && CGO_ENABLED=0 go build -o fail2ban-ui-agent ./cmd/agent
set -euo pipefail

echo "[custom-init] fail2ban-ui-agent: install from /mnt/fail2ban-ui-agent"
SRC=/mnt/fail2ban-ui-agent/fail2ban-ui-agent
DST=/usr/local/bin/fail2ban-ui-agent

if [ ! -f "$SRC" ]; then
  echo "[custom-init] ERROR: $SRC not found."
  echo "[custom-init] Build a static binary for Alpine, from repo root:"
  echo "  cd _dev/fail2ban-ui-agent && CGO_ENABLED=0 go build -o fail2ban-ui-agent ./cmd/agent"
  exit 1
fi

cp -f "$SRC" "$DST"
chmod 755 "$DST"
echo "[custom-init] installed $DST"
